                    }
                ],
                "description": "Runtime for Newfold WP modules and plugins",
                "support": {
                    "source": "https://github.com/newfold-labs/wp-module-runtime/tree/main",
                    "issues": "https://github.com/newfold-labs/wp-module-runtime/issues"
                }
            }
        ]
    }
